# Environment variables for Akiba Estate Backend
# Copy this file to .env and update with your values

# Flask Secret Key (change in production)
SECRET_KEY=super-secret-key-change-in-production

# JWT Secret Key (change in production)
JWT_SECRET=jwt-secret-key-change-in-production

# Database configuration
# Option 1: Full SQLAlchemy URL (recommended for production)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/estate

# Option 2: Discrete PostgreSQL settings (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=estate
# DB_USER=postgres
# DB_PASSWORD=your_password

# If neither DATABASE_URL nor DB_* PostgreSQL vars are set,
# the app falls back to a local SQLite file at backend/estate.db.

# JWT Token Expiration (hours)
JWT_EXPIRATION_HOURS=24

# Email Configuration (for OTP)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
